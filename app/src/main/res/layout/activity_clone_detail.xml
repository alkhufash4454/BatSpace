<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:padding="16dp" android:background="@color/bg_secondary">
            <ImageButton android:id="@+id/btnBack" android:layout_width="44dp"
                android:layout_height="44dp" android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_primary" />
            <TextView android:text="Clone Details" android:textColor="@color/text_primary"
                android:textSize="18sp" android:textStyle="bold" android:paddingStart="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- App icon + name -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="center" android:padding="28dp">
            <ImageView android:id="@+id/ivAppIcon" android:layout_width="80dp"
                android:layout_height="80dp" android:scaleType="fitCenter" />
            <TextView android:id="@+id/tvCloneName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="App Name"
                android:textColor="@color/text_primary" android:textSize="22sp"
                android:textStyle="bold" android:paddingTop="12dp" />
            <TextView android:id="@+id/tvInstance" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Instance #1"
                android:textColor="@color/accent_blue" android:textSize="13sp" android:paddingTop="4dp" />
            <TextView android:id="@+id/tvOriginalPackage" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="@color/text_hint"
                android:textSize="11sp" android:paddingTop="4dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="16dp">

            <!-- Virtual identity card -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:text="Virtual Identity" android:textColor="@color/accent_purple"
                        android:textSize="13sp" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="10dp" />
                    <TextView android:text="Android ID" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/tvAndroidId" android:textColor="@color/accent_cyan"
                        android:textSize="14sp" android:fontFamily="monospace"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="8dp" />
                    <TextView android:text="Device ID" android:textColor="@color/text_secondary"
                        android:textSize="12sp" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    <TextView android:id="@+id/tvDeviceId" android:textColor="@color/accent_cyan"
                        android:textSize="14sp" android:fontFamily="monospace"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingBottom="12dp" />
                    <Button android:id="@+id/btnRefreshIdentity" android:layout_width="match_parent"
                        android:layout_height="44dp" android:text="🔄 Regenerate Identity"
                        android:backgroundTint="@color/accent_purple" android:textColor="@color/white"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Controls -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:text="🔒 Lock this clone" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchLock"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:text="🔔 Notifications" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1" />
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchNotifications"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:checked="true" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnDelete" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="🗑️ Delete Clone"
                android:backgroundTint="@color/danger" android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
